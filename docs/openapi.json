        "description": "Mengembalikan data tren NG per hari yang disertai breakdown per-slot waktu.\nBerguna untuk mendeteksi pola produksi (jam berapa paling banyak NG).\n",
        "parameters": [
          {
            "in": "query",
            "name": "startDate",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "in": "query",
            "name": "endDate",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "in": "query",
            "name": "tipe_proses",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Data tren NG harian berhasil diambil"
          }
        }
      }
    },
    "/api/v1/dashboard/trend-combo": {
      "get": {
        "summary": "Q-Gate Combo Chart — Bar (Total Check/NG) + Line (Defect Rate %)",
        "tags": [
          "Dashboard"
        ],
        "description": "Data harian untuk Combo Chart Q-Gate Board.\n- `tipe_proses=PRESS` → hanya data PRESS\n- `tipe_proses=SEWING` → hanya data SEWING\n- Kosongkan `tipe_proses` → **GABUNGAN** semua proses (PRESS + SEWING + CUTTING)\n\nResponse mencakup `data_harian` (per tanggal) dan `ringkasan` (agregat global).\n",
        "parameters": [
          {
            "in": "query",
            "name": "startDate",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "in": "query",
            "name": "endDate",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "in": "query",
            "name": "tipe_proses",
            "schema": {
              "type": "string",
              "enum": [
                "PRESS",
                "CUTTING",
                "SEWING",
                "QUALITY_CONTROL"
              ]
            },
            "description": "Filter proses. Kosongkan untuk data GABUNGAN."
          }
        ],
        "responses": {
          "200": {
            "description": "Data Combo Chart berhasil diambil",
            "content": {
              "application/json": {
                "example": {
                  "status": "success",
                  "data": {
                    "data_harian": [
                      {
                        "tanggal": "2026-07-01",
                        "total_check_pcs": 500,
                        "total_ng_pcs": 12,
                        "total_ok_pcs": 488,
                        "defect_rate_persen": 2.4,
                        "sesi_count": 3
                      }
                    ],
                    "ringkasan": {
                      "total_check_pcs": 15000,
                      "total_ng_pcs": 320,
                      "total_ok_pcs": 14680,
                      "defect_rate_persen": 2.133
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/dashboard/pie-distribution": {
      "get": {
        "summary": "Q-Gate Pie Chart — Distribusi Semua Jenis Defect",
        "tags": [
          "Dashboard"
        ],
        "description": "Distribusi proporsi setiap jenis defect dari total NG.\n- `tipe_proses=PRESS` → distribusi defect hanya di PRESS\n- `tipe_proses=SEWING` → distribusi defect hanya di SEWING\n- Kosongkan `tipe_proses` → **GABUNGAN** semua proses\n",
        "parameters": [
          {
            "in": "query",
            "name": "startDate",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "in": "query",
            "name": "endDate",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "in": "query",
            "name": "tipe_proses",
            "schema": {
              "type": "string",
              "enum": [
                "PRESS",
                "CUTTING",
