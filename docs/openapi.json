    "/api/v1/dashboard/pareto": {
      "get": {
        "summary": "Pareto Chart - Top N defect dikelompokkan per 4 slot waktu",
        "tags": [
          "Dashboard"
        ],
        "description": "Mengembalikan data Pareto siap pakai untuk frontend.\nSetiap defect disertai persentase dari total NG, serta jumlah per-slot waktu\n(SLOT_1: 08:00-12:00, SLOT_2: 13:00-15:30, SLOT_3: 16:00-17:00, OVERTIME: 17:00+).\n",
        "parameters": [
          {
            "in": "query",
            "name": "startDate",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "in": "query",
            "name": "endDate",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "in": "query",
            "name": "tipe_proses",
            "schema": {
              "type": "string",
              "enum": [
                "PRESS",
                "CUTTING",
                "SEWING",
                "QUALITY_CONTROL"
              ]
            },
            "description": "Filter berdasarkan tipe proses"
          },
          {
            "in": "query",
            "name": "top_n",
            "schema": {
              "type": "integer",
              "default": 5
            },
            "description": "Jumlah Top-N defect yang diambil"
          },
          {
            "in": "query",
            "name": "exportPdf",
            "schema": {
              "type": "boolean"
            },
            "description": "Set to true to export the Pareto table as a PDF file"
          }
        ],
        "responses": {
          "200": {
            "description": "Data Pareto berhasil diambil atau PDF berhasil diunduh",
            "content": {
              "application/json": {
                "example": {
                  "status": "success",
                  "data": {
                    "pareto": [
                      {
                        "id_defect": "D01",
                        "nama_defect": "Goresan Dalam (Scratch)",
                        "total": 45,
                        "persentase": 60.5,
                        "per_slot": {
                          "08:00 - 12:00": 20,
                          "13:00 - 15:30": 15,
                          "16:00 - 17:00": 7,
                          "17:00 - Selesai": 3
                        }
                      }
                    ],
                    "total_ng_keseluruhan": 74
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/dashboard/trends": {
      "get": {
        "summary": "Tren Rasio NG harian dikelompokkan per slot waktu",
        "tags": [
