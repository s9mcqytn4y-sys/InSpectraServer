          "200": {
            "description": "Berhasil mendapatkan daftar defect"
          }
        }
      },
      "post": {
        "summary": "Menambahkan jenis defect baru",
        "tags": [
          "MasterData"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "id_defect",
                  "name",
                  "category"
                ],
                "properties": {
                  "id_defect": {
                    "type": "string"
                  },
                  "name": {
                    "type": "string"
                  },
                  "category": {
                    "type": "string",
                    "enum": [
                      "MATERIAL",
                      "PROSES"
                    ]
                  },
                  "deskripsi": {
                    "type": "string"
                  },
                  "severity_default": {
                    "type": "number"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Defect berhasil ditambahkan"
          }
        }
      }
    },
