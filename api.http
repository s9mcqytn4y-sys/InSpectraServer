@baseUrl = http://localhost:8000/api/v1
@authToken = {{login.response.body.data.token}}

### Authentication (TBD)
# Login endpoint placeholder (currently Auth is disabled/postponed)
# @name login
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "username": "admin",
  "password": "password"
}

### ========================================
### MASTER DATA
### ========================================

### Get All Parts
GET {{baseUrl}}/masterdata/parts
# Authorization: Bearer {{authToken}}

### Create New Part
POST {{baseUrl}}/masterdata/parts
Content-Type: application/json
# Authorization: Bearer {{authToken}}

{
  "uniqNo": "TEST-001",
  "part_no": "P-TEST-001",
  "name": "Test Part",
  "commodity": "PRESS",
  "catatan": "Test via API Client"
}

### Get All Materials
GET {{baseUrl}}/masterdata/materials
# Authorization: Bearer {{authToken}}

### Create New Material
POST {{baseUrl}}/masterdata/materials
Content-Type: application/json
# Authorization: Bearer {{authToken}}

{
  "code": "TEST-MAT",
  "name": "Test Material API",
  "kategori_material": "FABRIC",
  "satuan": "ROLL"
}

### Get All Defects
GET {{baseUrl}}/masterdata/defects
# Authorization: Bearer {{authToken}}

### Create New Defect
POST {{baseUrl}}/masterdata/defects
Content-Type: application/json
# Authorization: Bearer {{authToken}}

{
  "id_defect": "TEST-DEF",
  "name": "Test Defect API",
  "category": "PROSES",
  "deskripsi": "Defect buatan testing",
  "severity_default": 2
}


### ========================================
### CHECKSHEET
### ========================================

### Get Checksheet Sessions
GET {{baseUrl}}/checksheet/sessions
# Authorization: Bearer {{authToken}}

### Start Checksheet Session
POST {{baseUrl}}/checksheet/sessions
Content-Type: application/json

{
  "tipe_proses": "PRESS",
  "nama_shift": "SHIFT_1",
  "nama_operator": "Operator Test"
}

### Submit Checksheet Item
# (Catatan: id_sesi harus valid UUID dari database)
POST {{baseUrl}}/checksheet/item
Content-Type: application/json

{
  "id_sesi": "00000000-0000-0000-0000-000000000000",
  "uniq_no": "TEST-001",
  "jumlah_diperiksa": 100,
  "jumlah_ok": 90,
  "jumlah_ng": 10
}

### Submit Checksheet Defect
# (Catatan: id_item harus valid UUID dari item yang sudah dibuat)
POST {{baseUrl}}/checksheet/defect
Content-Type: application/json

{
  "id_item": "00000000-0000-0000-0000-000000000000",
  "id_defect": "TEST-DEF",
  "nama_defect_snapshot": "Test Defect API",
  "kategori": "PROSES",
  "jumlah": 5
}

### ========================================
### LAPORAN (REPORTING)
### ========================================

### Get All Laporan
GET {{baseUrl}}/laporan
# Authorization: Bearer {{authToken}}

### Create Laporan
POST {{baseUrl}}/laporan
Content-Type: application/json

{
  "tanggal": "2026-07-05T00:00:00Z",
  "tipe_proses": "PRESS",
  "mp_direct": 10,
  "mp_indirect": 2,
  "jkn_hour": 8
}

### Create Laporan Detail
# (Catatan: id_laporan dan id_part harus valid UUID)
POST {{baseUrl}}/laporan/detail
Content-Type: application/json

{
  "id_laporan": "00000000-0000-0000-0000-000000000000",
  "id_part": "00000000-0000-0000-0000-000000000000",
  "planning": 1000,
  "actual": 900,
  "ng": 10
}

### ========================================
### CUTTING
### ========================================

### Get Cutting Batches
GET {{baseUrl}}/cutting/batches
# Authorization: Bearer {{authToken}}

### Create Cutting Batch
# (Catatan: id_sesi dan material_id harus valid UUID)
POST {{baseUrl}}/cutting/batches
Content-Type: application/json

{
  "id_sesi": "00000000-0000-0000-0000-000000000000",
  "material_id": "00000000-0000-0000-0000-000000000000",
  "ukuran_cutting_cm": 150.5,
  "qty_layer_ok": 10,
  "qty_layer_ng": 1,
}

### ========================================
### DASHBOARD & ANALYTICS
### ========================================

### Get Top Defects
GET {{baseUrl}}/dashboard/top-defects
# Authorization: Bearer {{authToken}}

### Get OEE Metrics
GET {{baseUrl}}/dashboard/oee-metrics
# Authorization: Bearer {{authToken}}

### Get NG Rate (Reject Ratio)
GET {{baseUrl}}/dashboard/ng-rate
# Authorization: Bearer {{authToken}}

### Get Pareto Chart (PRESS)
GET {{baseUrl}}/dashboard/pareto?tipe_proses=PRESS&top_n=5

### Get Pareto Chart (SEWING)
GET {{baseUrl}}/dashboard/pareto?tipe_proses=SEWING&top_n=5

### Get Trend Harian per Slot
GET {{baseUrl}}/dashboard/trends?tipe_proses=PRESS

### ========================================
### Q-GATE DASHBOARD (NEW)
### ========================================

### --- PRESS ---

### Q-Gate Combo Chart (PRESS bulan ini)
GET {{baseUrl}}/dashboard/trend-combo?tipe_proses=PRESS&startDate=2026-07-01T00:00:00Z&endDate=2026-07-31T23:59:59Z

### Q-Gate Pie Distribution (PRESS bulan ini)
GET {{baseUrl}}/dashboard/pie-distribution?tipe_proses=PRESS&startDate=2026-07-01T00:00:00Z&endDate=2026-07-31T23:59:59Z

### Q-Gate Top 3 Defect + Breakdown Part (PRESS bulan ini)
GET {{baseUrl}}/dashboard/top3-defects?tipe_proses=PRESS&startDate=2026-07-01T00:00:00Z&endDate=2026-07-31T23:59:59Z&top_n=3

