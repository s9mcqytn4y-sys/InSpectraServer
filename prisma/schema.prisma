generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

model MasterPart {
  id                                               String                          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  uniqNo                                           String                          @unique @map("uniq_no")
  part_no                                          String?
  name                                             String                          @map("nama_part")
  model                                            String?
  customer                                         String?
  commodity                                        tipe_proses_inspectra           @map("komoditas")
  total_item_per_kanban                            Int?
  sample_item_per_kanban                           Int?
  sample_cycle_note                                String?
  lokasi_gambar                                    String?
  aktif                                            Boolean                         @default(true)
  dibuat_pada                                      DateTime                        @default(now()) @db.Timestamptz(6)
  diperbarui_pada                                  DateTime                        @default(now()) @db.Timestamptz(6)
  catatan                                          String?
  kode_internal                                    String?
  sumber_data                                      String                          @default("MANUAL")
  status_kelengkapan                               String                          @default("BELUM_DICEK")
  butuh_review                                     Boolean                         @default(false)
  catatan_review                                   String?
  dibuat_oleh                                      String?
  diperbarui_oleh                                  String?
  e_cutting_batch                                  CuttingBatch[]
  e_item_checksheet                                e_item_checksheet[]
  e_laporan_produksi_detail                        e_laporan_produksi_detail[]
  m_part_child_m_part_child_child_uniq_noTom_part  m_part_child[]                  @relation("m_part_child_child_uniq_noTom_part")
  m_part_child_m_part_child_parent_uniq_noTom_part m_part_child[]                  @relation("m_part_child_parent_uniq_noTom_part")
  m_part_cutting_size_reference                    m_part_cutting_size_reference[]
  m_part_defect                                    m_part_defect[]
  m_part_defect_override                           m_part_defect_override[]
  m_part_image                                     m_part_image?
  m_part_material                                  m_part_material[]

  @@index([commodity, uniqNo], map: "idx_m_part_komoditas_aktif", where: raw("(aktif = true)"))
  @@map("m_part")
}

model MasterMaterial {
  id                                                                       String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code                                                                     String?                    @unique @map("kode_material")
  name                                                                     String                     @map("nama_material")
  nama_normalisasi                                                         String?                    @default(dbgenerated("upper(TRIM(BOTH FROM regexp_replace(nama_material, '\\s+'::text, ' '::text, 'g'::text)))"))
  supplier_id                                                              String?                    @db.Uuid
  supplier_manual                                                          String?
  jenis_material                                                           String?
  spec_ringkas                                                             String?
  satuan                                                                   satuan_inspectra           @default(UNKNOWN)
  aktif                                                                    Boolean                    @default(true)
  dibuat_pada                                                              DateTime                   @default(now()) @db.Timestamptz(6)
  diperbarui_pada                                                          DateTime                   @default(now()) @db.Timestamptz(6)
  spec                                                                     String?
  kategori_material                                                        String?
  default_satuan                                                           String?
  sumber_data                                                              String                     @default("MANUAL")
  status_kelengkapan                                                       String                     @default("BELUM_DICEK")
  butuh_review                                                             Boolean                    @default(false)
  catatan_review                                                           String?
  dibuat_oleh                                                              String?
  diperbarui_oleh                                                          String?
  supplier                                                                 String?
  lebar_roll_cm                                                            Decimal?                   @db.Decimal
  panjang_roll_cm                                                          Decimal?                   @db.Decimal
  tebal_mm                                                                 Decimal?                   @db.Decimal
  berat_gsm                                                                Decimal?                   @db.Decimal
  gramasi_gsm                                                              Decimal?                   @db.Decimal
  warna                                                                    String?
  catatan_spesifikasi                                                      String?
  e_cutting_batch                                                          CuttingBatch[]
  m_cutting_size_reference                                                 m_cutting_size_reference[]
  m_supplier                                                               MasterSupplier?            @relation(fields: [supplier_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  m_material_defect                                                        m_material_defect[]
  m_material_komposisi_m_material_komposisi_child_material_idTom_material  m_material_komposisi[]     @relation("m_material_komposisi_child_material_idTom_material")
  m_material_komposisi_m_material_komposisi_parent_material_idTom_material m_material_komposisi[]     @relation("m_material_komposisi_parent_material_idTom_material")
  m_material_spec                                                          m_material_spec[]
  m_material_supplier                                                      m_material_supplier[]
  m_part_material                                                          m_part_material[]

  @@unique([nama_normalisasi, supplier_id, spec_ringkas])
  @@index([nama_normalisasi], map: "idx_m_material_search", where: raw("(aktif = true)"))
  @@map("m_material")
}

model MasterSupplier {
  id                  String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code                String?               @unique @map("kode_supplier")
  name                String                @unique @map("nama_supplier")
  kategori            String?
  alamat              String?
  kontak              String?
  aktif               Boolean               @default(true)
  dibuat_pada         DateTime              @default(now()) @db.Timestamptz(6)
  diperbarui_pada     DateTime              @default(now()) @db.Timestamptz(6)
  catatan             String?
  nama_normalisasi    String?
  kategori_supplier   String?
  sumber_data         String                @default("MANUAL")
  dibuat_oleh         String?
  diperbarui_oleh     String?
  m_material          MasterMaterial[]
  m_material_supplier m_material_supplier[]

  @@map("m_supplier")
}

model MasterDefect {
  id_defect               String                    @id
  name                    String                    @map("nama_defect")
  category                kategori_defect_inspectra @map("kategori")
  proses_default          tipe_proses_inspectra?
  aktif                   Boolean                   @default(true)
  dibuat_pada             DateTime                  @default(now()) @db.Timestamptz(6)
  deskripsi               String?
  severity_default        Int?
  diperbarui_pada         DateTime                  @default(now()) @db.Timestamptz(6)
  kode_display            String?
  satuan_input            String                    @default("PCS")
  metode_pengukuran       String                    @default("COUNT")
  proses_scope            String                    @default("ALL")
  warna_badge             String?
  icon_key                String?
  e_cutting_defect_detail e_cutting_defect_detail[]
  e_defect_checksheet     e_defect_checksheet[]
  m_material_defect       m_material_defect[]
  m_part_defect           m_part_defect[]
  m_part_defect_override  m_part_defect_override[]

  @@map("m_defect")
}

model MasterEmployee {
  id                String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nama_lengkap      String
  tipe_pekerja      tipe_pekerja_inspectra
  no_reg            String?                @unique
  line_process      tipe_proses_inspectra
  aktif             Boolean                @default(true)
  dibuat_pada       DateTime               @default(now()) @db.Timestamptz(6)
  diperbarui_pada   DateTime               @default(now()) @db.Timestamptz(6)
  t_rasio_kehadiran t_rasio_kehadiran[]

  @@map("m_karyawan")
}

model ChecksheetSession {
  id                  String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  kode_sesi           String?               @unique
  tipe_proses         tipe_proses_inspectra
  tanggal_pemeriksaan DateTime              @default(dbgenerated("CURRENT_DATE")) @db.Date
  nama_shift          String                @default("SHIFT_1")
  nama_operator       String?
  nama_line           String?
  device_id           String?
  app_version         String?
  total_diperiksa     Int                   @default(0)
  totalOk             Int                   @default(0) @map("total_ok")
  totalNg             Int                   @default(0) @map("total_ng")
  rasio_ng_global     Decimal               @default(0) @db.Decimal(8, 3)
  status              String                @default("TERKIRIM")
  dibuat_pada         DateTime              @default(now()) @db.Timestamptz(6)
  catatan             String?
  diperbarui_pada     DateTime              @default(now()) @db.Timestamptz(6)
  takt_time_seconds   Int?                  @default(0)
  e_cutting_batch     CuttingBatch[]
  e_item_checksheet   e_item_checksheet[]

  @@index([tanggal_pemeriksaan(sort: Desc), tipe_proses], map: "idx_e_sesi_tanggal_tipe")
  @@map("e_sesi_checksheet")
}

model CuttingBatch {
  id                            String                         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  id_sesi                       String                         @db.Uuid
  material_id                   String                         @db.Uuid
  material_spec_id              String?                        @db.Uuid
  tanggal                       DateTime                       @default(dbgenerated("CURRENT_DATE")) @db.Date
  no_lot_roll                   String?
  no_roll                       String?
  size_cutting_cm               Decimal?                       @db.Decimal(12, 3)
  roll_width_cm_snapshot        Decimal?                       @db.Decimal(12, 3)
  roll_length_cm_snapshot       Decimal?                       @db.Decimal(12, 3)
  qty_layer_ok                  Int                            @default(0)
  qty_layer_ng                  Int                            @default(0)
  waste_panjang_cm              Decimal                        @default(0) @db.Decimal(12, 3)
  pic                           String?
  catatan                       String?
  dibuat_pada                   DateTime                       @default(now()) @db.Timestamptz(6)
  diperbarui_pada               DateTime                       @default(now()) @db.Timestamptz(6)
  ukuran_cutting_cm             Decimal?                       @db.Decimal(12, 3)
  nama_material_snapshot        String?                        @db.VarChar
  nama_operator                 String?                        @db.VarChar
  spec_material_snapshot        String?
  uniq_no_part                  String?
  nama_part_snapshot            String?
  part_size_reference_id        String?                        @db.Uuid
  ukuran_manual                 Boolean                        @default(true)
  size_reference_id             String?                        @db.Uuid
  nomor_lot_roll                String?
  panjang_ok_cm                 Decimal?                       @db.Decimal(14, 3)
  panjang_ng_cm                 Decimal                        @default(0) @db.Decimal(14, 3)
  panjang_waste_cm              Decimal?                       @db.Decimal(14, 3)
  panjang_roll_awal_cm          Decimal?                       @db.Decimal(14, 3)
  jumlah_potong_ok              Int?
  sumber_input                  String                         @default("ANDROID")
  takt_time_seconds             Int?                           @default(0)
  e_sesi_checksheet             ChecksheetSession              @relation(fields: [id_sesi], references: [id], onDelete: Cascade, onUpdate: NoAction)
  m_material                    MasterMaterial                 @relation(fields: [material_id], references: [id], onUpdate: NoAction)
  m_material_spec               m_material_spec?               @relation(fields: [material_spec_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  m_part_cutting_size_reference m_part_cutting_size_reference? @relation(fields: [part_size_reference_id], references: [id], onUpdate: NoAction)
  m_cutting_size_reference      m_cutting_size_reference?      @relation(fields: [size_reference_id], references: [id], onUpdate: NoAction)
  m_part                        MasterPart?                    @relation(fields: [uniq_no_part], references: [uniqNo], onDelete: Restrict, onUpdate: NoAction)
  e_cutting_defect_detail       e_cutting_defect_detail[]

  @@index([uniq_no_part, part_size_reference_id], map: "idx_e_cutting_batch_part_reference")
  @@index([id_sesi], map: "idx_e_cutting_batch_sesi")
  @@map("e_cutting_batch")
}

